rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isDomainUser() {
      return request.auth != null && (
        request.auth.token.email.matches('.*@sis-kg.org') ||
        request.auth.token.email.matches('.*@SIS-KG.ORG')
      );
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isVendor() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    function isVendorVerificationOnlyUpdate() {
      return resource != null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selectedCCAs']) &&
             request.resource.data.studentUid == resource.data.studentUid &&
             request.resource.data.studentEmail == resource.data.studentEmail &&
             request.resource.data.studentName == resource.data.studentName &&
             request.resource.data.classId == resource.data.classId &&
             request.resource.data.classNameSnapshot == resource.data.classNameSnapshot &&
             request.resource.data.status == resource.data.status &&
             request.resource.data.selectedCCAs.size() == resource.data.selectedCCAs.size();
    }

    // NEW: Allow vendors to update grade fields in selectedCCAs
    // Simplified rule - just checks that selectedCCAs is being updated and other fields stay the same
    function isVendorGradeUpdate() {
      return resource != null &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selectedCCAs']) &&
             request.resource.data.studentUid == resource.data.studentUid &&
             request.resource.data.studentEmail == resource.data.studentEmail &&
             request.resource.data.studentName == resource.data.studentName;
    }

    match /users/{userId} {
      allow read: if isDomainUser() || isTeacher();
      allow write: if isDomainUser() && (request.auth.uid == userId || isAdmin());
    }

    match /classes/{id} {
      allow read: if isDomainUser() || isTeacher();
      allow write: if isDomainUser() && isAdmin();
    }

    match /ccas/{id} {
      allow read: if request.auth != null;
      allow create, delete: if isDomainUser() && isAdmin();
      allow update: if isDomainUser() && (
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['enrolledCount', 'students', 'updatedAt'])
      );
    }

    match /selections/{selectionId} {
      allow create: if isDomainUser() && (
        request.resource.data.studentUid == request.auth.uid || isAdmin()
      );

      allow update: if isDomainUser() && (
        isAdmin() ||
        request.resource.data.studentUid == request.auth.uid ||
        (isVendor() && isVendorVerificationOnlyUpdate()) ||
        (isVendor() && isVendorGradeUpdate())
      );

      allow delete: if isDomainUser() && (
        (resource != null && resource.data.studentUid == request.auth.uid) || isAdmin()
      );

      allow read: if isDomainUser() && (
        resource == null ||
        resource.data.studentUid == request.auth.uid ||
        isAdmin() ||
        isTeacher() ||
        isVendor()
      );
    }

    match /settings/{document=**} {
      allow read: if request.auth != null && (
        isDomainUser() ||
        isTeacher() ||
        isVendor() ||
        isAdmin()
      );
      allow write: if isDomainUser() && isAdmin();
    }

    match /vendors/{id} {
      allow read: if isDomainUser();
      allow write: if isDomainUser() && isAdmin();
    }
    
    // NEW: Add this rule for custom student lists
    match /customStudentLists/{docId} {
      allow read, write: if isDomainUser() && (
        (isTeacher() && docId == request.auth.uid + '_customList') ||
        isAdmin()
      );
    }

    match /attendanceRecords/{recordId} {
      allow read: if request.auth != null && isDomainUser() && (isTeacher() || isAdmin() || isVendor());
      allow write: if request.auth != null && isDomainUser() && (isTeacher() || isAdmin());
    }
  }
}
